-- ============================================================
-- TABLA: facultades
-- ============================================================
DROP TABLE IF EXISTS facultades;
CREATE TABLE facultades (
  id_facultad INT AUTO_INCREMENT PRIMARY KEY,
  nombre VARCHAR(150) NOT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

