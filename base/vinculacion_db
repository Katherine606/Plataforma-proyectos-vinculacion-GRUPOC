-- ============================================
-- TABLA: facultades
-- ============================================
CREATE TABLE facultades (
    id_facultad INT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(150) NOT NULL
);

INSERT INTO facultades (nombre) VALUES
('Facultad de Ingeniería'),
('Facultad de Ciencias de la Salud'),
('Facultad de Administración');

-- ============================================
-- TABLA: carreras
-- ============================================
CREATE TABLE carreras (
    id_carrera INT PRIMARY KEY AUTO_INCREMENT,
    facultad_id INT NOT NULL,
    nombre VARCHAR(150) NOT NULL,
    FOREIGN KEY (facultad_id) REFERENCES facultades(id_facultad)
);

INSERT INTO carreras (facultad_id, nombre) VALUES (1, 'Ingeniería en Sistemas'), (1, 'Ingeniería Civil'), (2, 'Medicina'), 
(3, 'Administración de Empresas');

-- ============================================
-- TABLA: proyectos
-- ============================================
CREATE TABLE proyectos (
    id_proyecto INT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(150) NOT NULL,
    descripcion TEXT NOT NULL,
    tutor_id INT NOT NULL,
    facultad_id INT NOT NULL,
    carrera_id INT NOT NULL,
    cupos_max INT NOT NULL,
    cupos_usados INT NOT NULL DEFAULT 0,
    estado VARCHAR(20) DEFAULT 'activo',
    fecha_inicio DATE NULL,
    fecha_fin DATE NULL,
    FOREIGN KEY (tutor_id) REFERENCES usuarios(id_usuario),
    FOREIGN KEY (facultad_id) REFERENCES facultades(id_facultad),
    FOREIGN KEY (carrera_id) REFERENCES carreras(id_carrera)
);

-- ============================================
-- TABLA: solicitudes
-- ============================================
CREATE TABLE solicitudes (
    id_solicitud INT PRIMARY KEY AUTO_INCREMENT,
    estudiante_id INT NOT NULL,
    proyecto_id INT NOT NULL,
    estado VARCHAR(20) DEFAULT 'pendiente',
    fecha_solicitud DATETIME NOT NULL,
    FOREIGN KEY (estudiante_id) REFERENCES usuarios(id_usuario),
    FOREIGN KEY (proyecto_id) REFERENCES proyectos(id_proyecto)
);

-- ============================================
-- TABLA: horas_vinculacion
-- ============================================
CREATE TABLE horas_vinculacion (
    id_hora INT PRIMARY KEY AUTO_INCREMENT,
    estudiante_id INT NOT NULL,
    proyecto_id INT NOT NULL,
    tutor_id INT NOT NULL,
    fecha_actividad DATE NOT NULL,
    descripcion TEXT NOT NULL,
    horas DECIMAL(5,2) NOT NULL,
    estado VARCHAR(20) DEFAULT 'Pendiente',
    FOREIGN KEY (estudiante_id) REFERENCES usuarios(id_usuario),
    FOREIGN KEY (proyecto_id) REFERENCES proyectos(id_proyecto),
    FOREIGN KEY (tutor_id) REFERENCES usuarios(id_usuario)
);

CREATE TABLE IF NOT EXISTS actividades (
  id_actividad INT AUTO_INCREMENT PRIMARY KEY,
  proyecto_id INT NOT NULL,
  tutor_id INT NOT NULL,
  fecha DATE NOT NULL,
  descripcion TEXT NOT NULL,
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);


