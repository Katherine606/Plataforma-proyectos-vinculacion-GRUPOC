
CREATE DATABASE IF NOT EXISTS vinculacion_db
CHARACTER SET utf8mb4 
COLLATE utf8mb4_unicode_ci; 

USE vinculacion_db;

-- ============================================
-- TABLA: roles
-- ============================================
CREATE TABLE roles (
    id_rol INT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(50) NOT NULL
);

